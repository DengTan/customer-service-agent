# ─── SmartAssist 智能客服 环境变量配置 ───────────────────
# 复制此文件为 .env.local 并填入实际值

# ─── Supabase 数据库 ──────────────────────────────────
# 从 Supabase 项目设置 → API 中获取
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── 加密密钥 ─────────────────────────────────────────
# 32字节十六进制字符串，用于 AES-256 加密
ENCRYPTION_KEY=your-encryption-key-32-bytes-hex

# ─── 运行环境 ─────────────────────────────────────────
NODE_ENV=development
COZE_PROJECT_ENV=DEV

# ─── JWT 认证 ─────────────────────────────────────────
# Base64 编码的密钥，建议使用 openssl rand -base64 32 生成
JWT_SECRET=your-jwt-secret-base64

# ─── 应用 URL ─────────────────────────────────────────
APP_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:5000

# ─── 内部 API ─────────────────────────────────────────
# 用于内部服务间认证的密钥
INTERNAL_API_SECRET=your-internal-api-secret

# ─── 千牛/淘宝平台 (可选) ─────────────────────────────
# QIANNIU_APP_KEY=
# QIANNIU_APP_SECRET=

# ─── Supabase Storage ─────────────────────────────────
# 在 Supabase Dashboard → Storage 创建 bucket 后填写
SUPABASE_STORAGE_BUCKET=smartassist

# ─── Ollama Embedding ─────────────────────────────────
# 本地 Ollama 服务（用于知识库向量化和检索）
# 下载地址: https://ollama.com/download
# 模型:
#   ollama pull bge-m3:567m      # 主模型（高精度嵌入）
#   ollama pull mxbai-embed-large # 备用模型（通用场景）
OLLAMA_BASE_URL=http://localhost:11434

# 主模型 (bge-m3:567m) - 高精度嵌入
# 备用模型 (mxbai-embed-large) - 当主模型不可用时自动降级
OLLAMA_EMBEDDING_MODEL_PRIMARY=bge-m3:567m
OLLAMA_EMBEDDING_MODEL_FALLBACK=mxbai-embed-large

# ─── Reranker (可选) ──────────────────────────────────
# 配置真实 cross-encoder 后，可信知识引用才会公开展示。
# 未配置或服务调用失败时自动降级，检索上下文仍可用于生成，但不会发布知识引用。
# BGE_RERANK_API_URL=http://localhost:8000
# BGE_RERANK_API_KEY=
# 或使用 Cohere，并在 settings 的 retrieval_hybrid_config 中选择 cohere 模型：
# COHERE_API_KEY=
# 通用兼容接口：
# RERANK_API_URL=
# RERANK_API_KEY=

# ─── 业务工具 API (可选) ──────────────────────────────
# ENABLE_REAL_TOOL_API=false
# ORDER_API_URL=
# ORDER_API_KEY=
# LOGISTICS_API_URL=
# LOGISTICS_API_KEY=
# REFUND_API_URL=
# REFUND_API_KEY=
