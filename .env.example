# ─── SmartAssist 智能客服 环境变量配置 ───────────────────
# 复制此文件为 .env.local 并填入实际值
# 所有标记为 [必填] 的变量必须在部署前配置

# ─── Supabase 数据库 ──────────────────────────────────
COZE_SUPABASE_URL=https://your-project.supabase.co           # [必填] Supabase 项目 URL
COZE_SUPABASE_ANON_KEY=eyJhbGciOi...                          # [必填] Supabase Anon Key
COZE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...                  # [可选] Service Role Key（服务端操作需要）

# ─── 加密密钥 ─────────────────────────────────────────
# 用于加密数据库中存储的敏感信息（平台 OAuth Token 等）
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=                                                # [必填] 至少 32 字符的随机字符串

# ─── 千牛/淘宝平台 (可选) ─────────────────────────────
# QIANNIU_APP_KEY=                                             # 千牛应用 App Key
# QIANNIU_APP_SECRET=                                          # 千牛应用 App Secret

# ─── S3 存储 (可选，用于图片上传) ──────────────────────
# S3_ENDPOINT=                                                 # S3 兼容存储端点
# S3_ACCESS_KEY_ID=                                            # S3 Access Key
# S3_SECRET_ACCESS_KEY=                                        # S3 Secret Key
# S3_BUCKET=                                                   # S3 Bucket 名称
# S3_REGION=                                                   # S3 Region

# ─── 运行环境 ─────────────────────────────────────────
# NODE_ENV=development                                         # development | production | test
# COZE_PROJECT_ENV=DEV                                         # DEV | PROD (Coze 平台环境标识)

# ─── 业务工具 API (可选) ────────────────────────────────
# 启用后将使用真实 API 查询订单/物流/退款，默认使用 Mock 数据
# ENABLE_REAL_TOOL_API=false                                   # true=真实API, false=Mock数据

# 订单查询 API (对接电商 ERP 或订单系统)
# ORDER_API_URL=https://api.your-erp.com/v1
# ORDER_API_KEY=your_order_api_key

# 物流查询 API (对接快递 100、菜鸟物流等)
# LOGISTICS_API_URL=https://api.kuaidi100.com/v1
# LOGISTICS_API_KEY=your_logistics_api_key

# 退款操作 API (对接支付平台退款接口，需商户资质)
# REFUND_API_URL=https://api.your-payment.com/v1
# REFUND_API_KEY=your_refund_api_key
